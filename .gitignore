# Virtual environment (created by setup_mww.sh)
.venv/

# Training artifacts (~15 GB: voices, features, clips, output)
training/

# Generated TTS preview samples
preview/

# Python cache
__pycache__/

# Trained model outputs (generated by export phase — copy to deployment manually)
*.onnx
*.tflite
*_mww.json

# Generated by setup_mww.sh (not committed — users run setup_mww.sh to create it)
run_mww.sh

# Training logs
training_log*.txt

# Personal recording sessions
record/

# WSL artifacts
*.Zone.Identifier

# Local Claude Code config
.claude/
